# Data (large files, may contain PII) — raw Lending Club CSVs excluded;
# see data/README.md for how to fetch them via Kaggle.
data/raw/
data/interim/
data/processed/*
!data/processed/macro_quarterly.csv

# Outputs (regenerated by pipeline)
outputs/*.pkl
outputs/*.parquet
outputs/metrics.json
reports/figures/eda/

# LaTeX build artifacts (final PDF IS committed; only intermediate build files are ignored)
reports/*.aux
reports/*.bbl
reports/*.bcf
reports/*.blg
reports/*.log
reports/*.out
reports/*.toc
reports/*.run.xml
reports/*.synctex*
reports/__pycache__/

# Pipeline run artefacts (regenerated by each run; never meant to be committed)
pipeline_*.log
pipeline_*.flag
pipeline_pid.txt

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Node (mcp-servers/*)
node_modules/

# Environments
.venv/
venv/
env/
ENV/

# Tools
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb_meta

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.env
kaggle.json

# Local dev tooling (not part of the deliverable)
.claude/
.mcp.json
mcp-servers/
.agents/



